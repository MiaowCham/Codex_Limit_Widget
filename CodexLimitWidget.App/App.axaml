<Application xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="CodexLimitWidget.App.App">
  <Application.Styles><FluentTheme /></Application.Styles>
  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/icon.ico" ToolTipText="Codex Limit Widget">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="隐藏窗口" Click="ToggleWindow_Click"/>
            <NativeMenuItem Header="取消置顶" Click="ToggleTopmost_Click"/>
            <NativeMenuItem Header="刷新" Click="Refresh_Click"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="版本 0.2.2" Click="OpenRepository_Click"/>
            <NativeMenuItem Header="退出" Click="Exit_Click"/>
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
</Application>
